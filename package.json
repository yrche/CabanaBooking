{
  "name": "CabanaBooking",
  "private": true,
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "server:dev": "npm run dev -w server --",
    "client:dev": "npm run dev -w client",
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "start": "npm run dev",
    "test": "npm run test -w server"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "dotenv": "^17.3.1",
    "socket.io": "^4.8.3",
    "sonner": "^2.0.7"
  }
}
